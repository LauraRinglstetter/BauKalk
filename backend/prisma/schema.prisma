// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  projectInfo ProjectInfo?

  rooms Room[]
}

model ProjectInfo {
  id         Int      @id @default(autoincrement())
  persons    Int
  floors     String[]
  houseType  String
  createdAt  DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId Int @unique
}

model RoomCategory {
  id    Int    @id @default(autoincrement())
  key   String @unique
  name  String @unique

  type  String @default("room")

  templates RoomTemplate[]

  furnitureTemplates FurnitureTemplate[] 
}

model RoomTemplate {
  id         Int    @id @default(autoincrement())
  name       String

  category   RoomCategory @relation(fields: [categoryId], references: [id])
  categoryId Int

  rooms      Room[]
  @@unique([name, categoryId])
}

model Room {
  id        Int    @id @default(autoincrement())
  name      String
  floor     String
  note      String?

  project   Project @relation(fields: [projectId], references: [id])
  projectId Int

  template   RoomTemplate? @relation(fields: [templateId], references: [id])
  templateId Int?

  furnitures Furniture[]

  kitchenItems KitchenItem[]

  kitchenDoors              KitchenDoor[]
  kitchenStorageTypeSpacing KitchenStorageTypeSpacing[]


  @@unique([projectId, templateId])
}

model Furniture {
  id        Int     @id @default(autoincrement())
  name      String

  width     Float
  depth     Float

  side1     Float   // seitlich 1
  side2     Float   // seitlich 2
  front     Float   // vorne
  back      Float   // hinten

  quantity  Int

  room      Room    @relation(fields: [roomId], references: [id])
  roomId    Int

  template   FurnitureTemplate? @relation(fields: [templateId], references: [id])
  templateId Int?
}

model FurnitureTemplate {
  id       Int    @id @default(autoincrement())
  name     String

  // optional: Default-Werte aus Excel
  width    Float?
  depth    Float?
  side1    Float?
  side2    Float?
  front    Float?
  back     Float?

  category   RoomCategory @relation(fields: [categoryId], references: [id])
  categoryId Int

  @@unique([name, categoryId])

  furnitures Furniture[]
}

model KitchenTemplate {
  id Int @id @default(autoincrement())

  name String @unique
  group String // "Großgeräte" | "Kleingeräte" | "Töpfe" 
  defaultQuantity Int    @default(0) 
  width Float?
  depth Float?
  height Float?
  

  storageType   KitchenStorageType @relation(fields: [storageTypeId], references: [id])
  storageTypeId Int

  items KitchenItem[]

}

model KitchenStorageType {
  id   Int    @id @default(autoincrement())
  key  String @unique
  name String

  templates KitchenTemplate[]
  items KitchenItem[]

}

model KitchenItem {
  id Int @id @default(autoincrement())
  customItemKey String? @unique 

  name String

  width Float
  depth Float
  height Float?

  quantity Int

  room Room @relation(fields: [roomId], references: [id])
  roomId Int

  template KitchenTemplate? @relation(fields: [templateId], references: [id])
  templateId Int?

  group String?  // nur für Custom-Items relevant

  storageType KitchenStorageType @relation(fields: [storageTypeId], references: [id])
  storageTypeId Int

  @@unique([roomId, templateId])
}

model KitchenDoor {
  id       Int    @id @default(autoincrement())
  type     String // "innentuer" | "durchgang" | "aussentuer"
  quantity Int
  width    Float
  depth    Float
  side1    Float  @default(0)
  side2    Float  @default(0)
  front    Float  @default(0.65)
  back     Float  @default(0)

  room   Room @relation(fields: [roomId], references: [id])
  roomId Int

  @@unique([roomId, type])
}

model KitchenStorageTypeSpacing {
  id              Int    @id @default(autoincrement())
  storageTypeName String
  side1           Float  @default(0)
  side2           Float  @default(0)
  front           Float  @default(0.65)
  back            Float  @default(0)

  room   Room @relation(fields: [roomId], references: [id])
  roomId Int

  @@unique([roomId, storageTypeName])
}